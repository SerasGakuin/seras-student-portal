# ============================================================
# .env.example
# 実際の値に置き換えて .env にリネームしてください
# ============================================================


# --- Google Service Account ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=myproject@my-gcp-project.iam.gserviceaccount.com
# 改行は \n でエスケープすること
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASC...\n-----END PRIVATE KEY-----\n"


# --- Spreadsheet / Calendar ---
OCCUPANCY_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
CALENDAR_ID=myproject-calendar@group.calendar.google.com


# --- LINE (LIFF / Messaging API) ---
NEXT_PUBLIC_LIFF_ID=1234567890-abcdefgh
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here


# --- Google OAuth (Dashboard Auth) ---
GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here
NEXTAUTH_SECRET=openssl_rand_base64_32_の出力結果をここに
NEXTAUTH_URL=https://your-app.vercel.app
# 複数アドレスはカンマ区切り
ALLOWED_EMAILS=admin@example.com,dev@example.com